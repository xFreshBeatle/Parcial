@model Parcial.Models.SolicitudCredito

@{
    ViewData["Title"] = "Detalle de solicitud";
}

<h1 class="mb-3">Detalle de solicitud #@Model.Id</h1>

<div class="card">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">Cliente</dt>
            <dd class="col-sm-8">@Model.ClienteId</dd>

            <dt class="col-sm-4">Monto solicitado</dt>
            <dd class="col-sm-8">@Model.MontoSolicitado.ToString("C")</dd>

            <dt class="col-sm-4">Fecha solicitud</dt>
            <dd class="col-sm-8">@Model.FechaSolicitud.ToString("yyyy-MM-dd HH:mm")</dd>

            <dt class="col-sm-4">Estado</dt>
            <dd class="col-sm-8">@Model.Estado</dd>

            <dt class="col-sm-4">Motivo rechazo</dt>
            <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.MotivoRechazo) ? "N/A" : Model.MotivoRechazo)</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary">Volver a mis solicitudes</a>
</div>
